# Git Diff / Merge 行为定制
# 锁文件：union merge 减少冲突
package-lock.json      text eol=lf -diff merge=union
yarn.lock              text eol=lf -diff merge=union
pnpm-lock.yaml         text eol=lf -diff merge=union
Cargo.lock             text eol=lf -diff merge=union
Pipfile.lock           text eol=lf -diff merge=union
Gemfile.lock           text eol=lf -diff merge=union
composer.lock          text eol=lf -diff merge=union

# Minified 文件不 diff
*.min.js               -diff
*.min.css              -diff
*.min.mjs              -diff

# CHANGELOG / VERSION：union merge
CHANGELOG*             merge=union
VERSION                merge=union

# Git 子模块
.gitmodules            text eol=lf

# 导出时排除（git archive 打包发布时自动剔除）
.gitattributes         export-ignore
.gitignore             export-ignore
.gitmodules            export-ignore
.github/               export-ignore
.gitlab-ci.yml         export-ignore
.travis.yml            export-ignore
.pre-commit-config.yaml export-ignore
.editorconfig          export-ignore
.vscode/               export-ignore
.idea/                 export-ignore
tests/                 export-ignore
test/                  export-ignore
*.test.*               export-ignore
*_test.*               export-ignore
